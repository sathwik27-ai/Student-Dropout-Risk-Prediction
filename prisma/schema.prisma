// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  passwordHash      String
  role              UserRole  @default(STUDENT)
  enrollmentYear    Int?
  program           String?   // e.g., "B.Tech", "MBBS"
  department        String?
  currentYear       Int?
  gpa               Float?
  attendancePercentage Float?
  assignmentsMissed Int?
  socioEconomicStatus String?
  distanceFromCollegeKm Float?
  monthlyIncome     Float?
  priorBacklogs     Int?
  extracurricularHours Float?
  mentalHealthScore Float?
  otherFeatures     Json?     // Store additional features as JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  roadmaps          Roadmap[]
  uploadedStudents  Student[] @relation("UploadedByTeacher")
  batchJobs         BatchJob[]

  @@map("users")
}

model Student {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  program               String    // e.g., "B.Tech", "MBBS"
  department            String?
  currentYear           Int
  gpa                   Float
  attendancePercentage  Float
  assignmentsMissed     Int
  socioEconomicStatus   String?
  distanceFromCollegeKm Float?
  monthlyIncome         Float?
  priorBacklogs         Int?
  extracurricularHours  Float?
  mentalHealthScore     Float?
  otherFeatures         Json?     // Store additional features as JSON
  uploadedBy            String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  predictions           Prediction[]
  uploader              User?     @relation("UploadedByTeacher", fields: [uploadedBy], references: [id])

  @@map("students")
}

model Prediction {
  id            String   @id @default(cuid())
  studentId     String
  riskPercent   Float
  riskCategory  RiskCategory
  features      Json     // Store feature values used for prediction
  explanation   Json?    // Store SHAP-like explanations
  modelVersion  String   @default("v1.0")
  createdAt     DateTime @default(now())

  // Relations
  student       Student? @relation(fields: [studentId], references: [id])

  @@map("predictions")
}

model Roadmap {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  description String?
  targetCareer String?
  program     String
  currentYear Int
  totalYears  Int
  content     Json     // Structured roadmap content (semesters, courses, projects, etc.)
  status      RoadmapStatus @default(DRAFT)
  isAccepted  Boolean  @default(false)
  generatedBy String   @default("ai") // "ai" or "manual"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User?    @relation(fields: [studentId], references: [id])

  @@map("roadmaps")
}

model BatchJob {
  id          String      @id @default(cuid())
  userId      String
  fileName    String
  totalRows   Int
  processedRows Int      @default(0)
  status      BatchStatus @default(PENDING)
  progress    Float       @default(0)
  error       String?
  resultFile  String?     // Path to result CSV file
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  // Relations
  user        User        @relation(fields: [userId], references: [id])

  @@map("batch_jobs")
}

model Resource {
  id          String       @id @default(cuid())
  title       String
  type        ResourceType
  topic       String
  description String?
  url         String?
  author      String?
  provider    String?
  duration    String?      // For videos/courses
  difficulty  String?      // Beginner, Intermediate, Advanced
  rating      Float?
  tags        String?      // Comma-separated tags
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("resources")
}

model InterventionTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  riskCategory RiskCategory
  subject     String
  body        String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("intervention_templates")
}

// Enums
enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum RiskCategory {
  LOW
  MEDIUM
  HIGH
}

enum RoadmapStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ResourceType {
  BOOK
  VIDEO
  COURSE
  ARTICLE
  CERTIFICATION
}